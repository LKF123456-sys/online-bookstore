<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 从 Spring 环境中读取应用名称 -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="bookstore"/>
    <springProperty scope="context" name="LOG_LEVEL" source="logging.level.com.bookstore" defaultValue="INFO"/>

    <!-- 控制台输出格式 -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n"/>

    <!-- ==================== 控制台 Appender ==================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 业务日志级别配置 ==================== -->
    <logger name="com.bookstore" level="${LOG_LEVEL}"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.cloud.gateway" level="INFO"/>
    <logger name="com.baomidou.mybatisplus" level="WARN"/>

    <!-- ==================== Root Logger ==================== -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
